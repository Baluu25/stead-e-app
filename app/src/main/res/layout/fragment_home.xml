<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="@color/color_text"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Streak Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥"
                    android:textSize="28sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvCurrentStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/color_primary"
                        android:textSize="32sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="day streak"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Longest streak:"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvLongestStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 days"
                android:textColor="@color/color_text"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- Week days -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="M"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay2"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="T"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay3"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="W"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay4"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="T"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay5"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="F"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay6"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <View
                        android:id="@+id/tvDay7"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_streak_circle"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Daily Progress Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Progress"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvProgressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 of 0 habits done today"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <ProgressBar
                android:id="@+id/progressToday"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="1"
                android:progress="0"
                android:progressTint="@color/color_primary"
                android:progressBackgroundTint="@color/color_border"/>

        </LinearLayout>

        <!-- Achievements button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewAchievements"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="View Achievements"
            android:textSize="15sp"
            style="@style/SteadE.Button.Outline"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</ScrollView>
