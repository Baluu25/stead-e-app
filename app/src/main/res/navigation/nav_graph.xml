<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.steade.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_achievements"
            app:destination="@id/achievementsFragment"/>
    </fragment>

    <fragment
        android:id="@+id/habitsFragment"
        android:name="com.steade.app.ui.habits.HabitsFragment"
        android:label="Habits"
        tools:layout="@layout/fragment_habits"/>

    <fragment
        android:id="@+id/goalsFragment"
        android:name="com.steade.app.ui.goals.GoalsFragment"
        android:label="Goals"
        tools:layout="@layout/fragment_goals"/>

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.steade.app.ui.statistics.StatisticsFragment"
        android:label="Statistics"
        tools:layout="@layout/fragment_statistics"/>

    <fragment
        android:id="@+id/achievementsFragment"
        android:name="com.steade.app.ui.achievements.AchievementsFragment"
        android:label="Achievements"
        tools:layout="@layout/fragment_achievements"/>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.steade.app.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile"/>

</navigation>
